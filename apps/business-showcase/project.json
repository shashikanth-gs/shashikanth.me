{
  "name": "business-showcase",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/business-showcase/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "dependsOn": ["generate-seo-assets"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/business-showcase",
        "browser": "apps/business-showcase/src/main.ts",
        "server": "apps/business-showcase/src/main.server.ts",
        "index": "apps/business-showcase/src/index.html",
        "outputMode": "static",
        "ssr": {
          "entry": "apps/business-showcase/src/server.ts"
        },
        "tsConfig": "apps/business-showcase/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/business-showcase/public"
          }
        ],
        "styles": ["apps/business-showcase/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "business-showcase:build:production"
        },
        "development": {
          "buildTarget": "business-showcase:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "generate-sitemap": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/generate-sitemap.mjs"
      }
    },
    "generate-seo-assets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/generate-seo-assets.mjs"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {}
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "business-showcase:build",
        "port": 4200,
        "staticFilePath": "dist/apps/business-showcase",
        "spa": true
      }
    }
  }
}
